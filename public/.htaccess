Options -MultiViews

<IfModule mod_rewrite.c>
RewriteEngine On

# Keep one host/protocol for all indexed URLs.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.aia\.in\.net$ [NC]
RewriteRule ^ https://aia.in.net%{REQUEST_URI} [R=301,L]

# Retired page URLs must redirect instead of serving SPA/homepage HTML.
RewriteRule ^about-us/?$ /about-aia/ [R=301,L]
RewriteRule ^passed-out/?$ /alumni-network/ [R=301,L]
RewriteRule ^our-passouts/?$ /alumni-network/ [R=301,L]
RewriteRule ^corpo/?$ /corporate-training/ [R=301,L]
RewriteRule ^enroll/?$ /enroll-now/ [R=301,L]
RewriteRule ^about-aia/cia-curriculum/?$ /cia-curriculum/ [R=301,L]
RewriteRule ^about-aia/cams/?$ /cams/ [R=301,L]
RewriteRule ^about-aia/cfe-curriculum/?$ /cfe-curriculum/ [R=301,L]
RewriteRule ^about-aia/cia-challenge-curriculum/?$ /cia-challenge-curriculum/ [R=301,L]
RewriteRule ^corporate-training/cia-curriculum/?$ /cia-curriculum/ [R=301,L]
RewriteRule ^corporate-training/cams/?$ /cams/ [R=301,L]
RewriteRule ^corporate-training/cfe-curriculum/?$ /cfe-curriculum/ [R=301,L]

# Legacy article URLs.
RewriteRule ^what-is-money-laundering/?$ /blogs/what-is-money-laundering/ [R=301,L]
RewriteRule ^academy-of-internal-audit-national-recognition/?$ /blogs/academy-of-internal-audit-national-recognition/ [R=301,L]
RewriteRule ^cfe-vs-cams/?$ /blogs/cfe-vs-cams/ [R=301,L]
RewriteRule ^cia-vs-cia-challenge-curriculum/?$ /blogs/cia-vs-cia-challenge-curriculum/ [R=301,L]
RewriteRule ^what-is-fraud/?$ /blogs/what-is-fraud/ [R=301,L]
RewriteRule ^anti-money-laundering-certificate/?$ /blogs/anti-money-laundering-certificate/ [R=301,L]
RewriteRule ^online-vs-offline-cfe-training/?$ /blogs/online-vs-offline-cfe-training/ [R=301,L]
RewriteRule ^cams-exam-format/?$ /blogs/cams-exam-format/ [R=301,L]
RewriteRule ^anti-money-laundering-jobs-salary/?$ /blogs/anti-money-laundering-jobs-salary/ [R=301,L]
RewriteRule ^certified-fraud-examiner-salary/?$ /blogs/certified-fraud-examiner-salary/ [R=301,L]
RewriteRule ^cia-certification/?$ /blogs/cia-certification/ [R=301,L]
RewriteRule ^cfe-module-4/?$ /blogs/cfe-module-4/ [R=301,L]
RewriteRule ^cia-certification-in-qatar/?$ /blogs/cia-certification-in-qatar/ [R=301,L]
RewriteRule ^cams-2025-syllabus-update-key-changes-and-preparation-guide/?$ /blogs/cams-syllabus/ [R=301,L]
RewriteRule ^cia-part-3-syllabus-2025/?$ /blogs/cia-part-3-syllabus/ [R=301,L]
RewriteRule ^cia-part-2-syllabus-2025/?$ /blogs/cia-part-2-syllabus/ [R=301,L]
RewriteRule ^internal-audit-101-everything-you-should-know/?$ /blogs/internal-audit/ [R=301,L]
RewriteRule ^cia-part1-syllabus-2025-update-internal-audit-fundamentals/?$ /blogs/cia-part-1-syllabus/ [R=301,L]
RewriteRule ^cfe-exam-home-test-center/?$ /blogs/cfe-exam-home-test-center/ [R=301,L]
RewriteRule ^cfe-exam-fees-and-retake-policy/?$ /blogs/cfe-exam-fees-and-retake-policy/ [R=301,L]
RewriteRule ^cia-exam-syllabus-2025-update/?$ /blogs/cia-exam-syllabus/ [R=301,L]
RewriteRule ^unlock-your-cfe-exam-success-with-these-proven-strategies/?$ /blogs/cfe-exam-success/ [R=301,L]
RewriteRule ^cia-exam-preparation-tips-for-cracking-exam-in-first-attempt/?$ /blogs/cia-exam-preparation-tips/ [R=301,L]
RewriteRule ^how-cams-certification-prepares-you-for-the-aml-career/?$ /blogs/aml-career/ [R=301,L]
RewriteRule ^curriculum-of-certified-fraud-examiner-module3-investigation/?$ /blogs/cfe-module-3/ [R=301,L]
RewriteRule ^the-impact-of-digital-tools-and-platforms-on-internal-audit-work/?$ /blogs/internal-audit-work/ [R=301,L]
RewriteRule ^how-cams-certification-equips-you-for-global-aml-challenges/?$ /blogs/aml-challenges/ [R=301,L]
RewriteRule ^curriculum-of-certified-fraud-examiner-module-2-law/?$ /blogs/cfe-module-2/ [R=301,L]
RewriteRule ^business-knowledge-for-internal-auditing-cia-part-3-curriculum/?$ /blogs/cia-part-3-curriculum/ [R=301,L]
RewriteRule ^job-opportunities-with-certified-fraud-examiner-certification/?$ /blogs/cfe-job-opportunities/ [R=301,L]
RewriteRule ^cfe-module-1-financial-transactions-and-fraud-schemes/?$ /blogs/cfe-module-1/ [R=301,L]
RewriteRule ^practice-of-internal-auditing-\(cia-part-2-curriculum\)/?$ /blogs/cia-part-2-curriculum/ [R=301,L]
RewriteRule ^essentials-of-internal-auditing-\(cia-part-1-curriculum\)/?$ /blogs/cia-part-1-curriculum/ [R=301,L]
RewriteRule ^your-guide-to-success-with-a-fraud-analyst-course/?$ /blogs/fraud-analyst-course/ [R=301,L]
RewriteRule ^a-step-by-step-guide-to-the-cia-exam-registration-process/?$ /blogs/cia-exam-registration-process/ [R=301,L]
RewriteRule ^essential-fraud-examiner-skills-to-avoid-and-spot-fraud/?$ /blogs/cfe-fraud-skills/ [R=301,L]
RewriteRule ^a-detailed-guide-on-certified-internal-auditor-functions/?$ /blogs/certified-internal-auditor-functions/ [R=301,L]
RewriteRule ^top-10-cams-exam-tips-to-pass-on-your-first-attempt/?$ /blogs/cams-exam-tips/ [R=301,L]
RewriteRule ^how-to-become-the-best-fraud-investigator/?$ /blogs/fraud-investigator/ [R=301,L]
RewriteRule ^what-are-the-cia-course-eligibility-criteria-in-india/?$ /blogs/cia-course-eligibility-criteria/ [R=301,L]
RewriteRule ^comprehensive-guide-to-understand-and-implement-kyc-compliance/?$ /blogs/kyc-compliance/ [R=301,L]
RewriteRule ^which-certifications-are-related-to-aml-compliance/?$ /blogs/aml-compliance/ [R=301,L]
RewriteRule ^what-is-the-cams-certification-cost-and-the-benefits/?$ /blogs/cams-certification-cost/ [R=301,L]
RewriteRule ^what-is-the-cia-certification-cost-and-duration-in-india/?$ /blogs/cia-certification-cost-duration-india/ [R=301,L]
RewriteRule ^internal-audits-role-in-fraud-prevention-and-detection/?$ /blogs/role-of-internal-audit-fraud/ [R=301,L]
RewriteRule ^understanding-the-role-of-a-certified-fraud-examiner-in-todays-business-landscape/?$ /blogs/certified-fraud-examiner-role/ [R=301,L]
RewriteRule ^what-are-the-practical-steps-in-an-internal-audit/?$ /blogs/steps-of-internal-audit/ [R=301,L]
RewriteRule ^certified-fraud-examiners-everything-you-need-to-know/?$ /blogs/certified-fraud-examiner/ [R=301,L]
RewriteRule ^what-are-the-benefits-of-becoming-cia/?$ /blogs/benefits-of-becoming-cia/ [R=301,L]
RewriteRule ^the-impact-of-cfe-in-corporate-world/?$ /blogs/cfe-in-corporate-world/ [R=301,L]
RewriteRule ^5-key-skills-required-to-pass-cia-exam/?$ /blogs/cia-exam-key-skills/ [R=301,L]
RewriteRule ^cfe-certification-cost-in-india/?$ /blogs/cfe-certification-cost/ [R=301,L]
RewriteRule ^how-to-achieve-cfe-certification-in-less-than-30-days/?$ /blogs/achieve-cfe-certification/ [R=301,L]
RewriteRule ^why-we-should-become-cfe/?$ /blogs/benefits-of-becoming-cfe/ [R=301,L]
RewriteRule ^steps-to-become-cfe/?$ /blogs/steps-to-become-cfe/ [R=301,L]
RewriteRule ^schedule-of-classes/?$ /blogs/schedule-of-classes/ [R=301,L]

# The live static host serves directory URLs, so canonical routes need a slash.
RewriteCond %{REQUEST_URI} !^/webapi/ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.[^/]+$
RewriteRule ^(.+)$ /$1/ [R=301,L]

# SPA fallback for routes not prerendered as static directories.
RewriteCond %{REQUEST_URI} !^/webapi/ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
</IfModule>
