{
  "trailingSlash": true,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.aia.in.net"
        }
      ],
      "destination": "https://aia.in.net/:path*",
      "permanent": true
    },
    {
      "source": "/about-us",
      "destination": "/about-aia/",
      "permanent": true
    },
    {
      "source": "/passed-out(/)?",
      "destination": "/alumni-network/",
      "permanent": true
    },
    {
      "source": "/our-passouts(/)?",
      "destination": "/alumni-network/",
      "permanent": true
    },
    {
      "source": "/corpo",
      "destination": "/corporate-training/",
      "permanent": true
    },
    {
      "source": "/enroll",
      "destination": "/enroll-now/",
      "permanent": true
    },
    {
      "source": "/about-aia/cia-curriculum",
      "destination": "/cia-curriculum/",
      "permanent": true
    },
    {
      "source": "/about-aia/cams",
      "destination": "/cams/",
      "permanent": true
    },
    {
      "source": "/about-aia/cfe-curriculum",
      "destination": "/cfe-curriculum/",
      "permanent": true
    },
    {
      "source": "/about-aia/cia-challenge-curriculum",
      "destination": "/cia-challenge-curriculum/",
      "permanent": true
    },
    {
      "source": "/corporate-training/cia-curriculum",
      "destination": "/cia-curriculum/",
      "permanent": true
    },
    {
      "source": "/corporate-training/cams",
      "destination": "/cams/",
      "permanent": true
    },
    {
      "source": "/corporate-training/cfe-curriculum",
      "destination": "/cfe-curriculum/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(webp|jpg|jpeg|png|svg|ico|woff2|woff)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
